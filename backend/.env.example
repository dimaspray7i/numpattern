APP_NAME=NumPattern
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5500

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=numpattern
# DB_USERNAME=root
# DB_PASSWORD=

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# Sanctum & CORS Configuration
SANCTUM_STATEFUL_DOMAINS=localhost:5500,127.0.0.1:5500,localhost:8000,127.0.0.1:8000

# CORS Allowed Origins
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@numpattern.com"
MAIL_FROM_NAME="NumPattern Game"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Rate Limiting
API_RATE_LIMIT=60
API_AUTH_RATE_LIMIT=10

# Game Configuration
GAME_TIME_LIMIT=60
GAME_BASE_SCORE=10
GAME_PENALTY_SCORE=5
GAME_STARTING_LIVES=3

VITE_APP_NAME="${APP_NAME}"